<% layout('layouts/boilerplate.ejs') %>

<h1 class="fs-2 pb-3">Daftar Assignment</h1>

<% if(assignments.length === 0) { %>
<p class="text-muted">Belum ada assignment tersedia.</p>
<% } else { %>

<div class="row">
  <% for(let assignment of assignments) { %>
  <div class="col-lg-4">
    <div class="card mb-4" style="height: 20rem">
      <div class="card-body">
        <h5 class="card-title"><%= truncate(assignment.title, 30) %></h5>
        <p class="card-text text-muted"><%= truncate(assignment.description, 100) %></p>
        <% if (assignment.deadline) { %>
        <p class="text-danger mb-2"><b>Deadline:</b> <%= new Date(assignment.deadline).toLocaleDateString() %></p>
        <% } %>
        <p class="text-secondary"><small>Dibuat oleh: <%= assignment.createdBy.name %></small></p>
      </div>
      <div class="card-footer">
        <a href="/assignments/<%= assignment._id %>" class="btn btn-sm btn-primary">Lihat Assignment</a>
      </div>
    </div>
  </div>
  <% } %>
</div>

<% } %> <% function truncate(text, maxLength) { if (!text) return ''; return text.length > maxLength ? text.slice(0, maxLength) + "..." : text; } %>
